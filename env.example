# Django Settings
SECRET_KEY=your-secret-key-here-generate-new-one
DEBUG=False
ALLOWED_HOSTS=caromoto-lt.com,www.caromoto-lt.com,your-server-ip

# Database Settings (PostgreSQL)
DB_NAME=logist2_db
DB_USER=logist2_user
DB_PASSWORD=your-strong-database-password
DB_HOST=localhost
DB_PORT=5432

# Security Settings
CSRF_TRUSTED_ORIGINS=https://caromoto-lt.com,https://www.caromoto-lt.com
CORS_ALLOWED_ORIGINS=https://caromoto-lt.com,https://www.caromoto-lt.com

# Email Settings (опционально, для отправки уведомлений)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# AI Settings (для AI чата)
AI_CHAT_ENABLED=True
AI_API_KEY=your-openai-api-key-here
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=400
AI_TEMPERATURE=0.2
AI_EMBEDDINGS_MODEL=text-embedding-3-small
AI_RAG_INDEX_PATH=
AI_RAG_TOP_K=4
AI_RAG_MAX_AGE_HOURS=24

# Media and Static Files
MEDIA_ROOT=/var/www/caromoto-lt/media
STATIC_ROOT=/var/www/caromoto-lt/static

# Sentry (error monitoring) — оставьте SENTRY_DSN пустым, чтобы отключить
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_PII=False

# Django settings module (обычно задаётся в systemd unit, не в .env)
# DJANGO_SETTINGS_MODULE=logist2.settings.prod

# ─────────────────────────────────────────────────────────────────────────────
# Gmail OAuth — переписка по контейнерам (Phase 1: только чтение)
# ─────────────────────────────────────────────────────────────────────────────
# Включение/выключение синхронизации с Gmail.
GMAIL_ENABLED=false
# OAuth 2.0 Desktop client — получить через Google Cloud Console (Logist2-email).
GMAIL_CLIENT_ID=816142178998-xxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx
# Refresh token — получить один раз через scripts/get_gmail_refresh_token.py.
GMAIL_REFRESH_TOKEN=1//0xxxxxxxxxxxxxxxx
# Почтовый ящик, к которому выдан токен (для справки/логов; API определяет сам).
GMAIL_USER_EMAIL=user@caromoto.com
# Сколько дней писем тянуть при первом прогоне (когда ещё нет history_id).
GMAIL_INITIAL_LOOKBACK_DAYS=30
# Лимит размера одного вложения для скачивания (МБ). Крупнее — только метаданные.
GMAIL_MAX_ATTACHMENT_MB=25

