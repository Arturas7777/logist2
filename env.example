# Django Settings
SECRET_KEY=your-secret-key-here-generate-new-one
DEBUG=False
ALLOWED_HOSTS=caromoto-lt.com,www.caromoto-lt.com,your-server-ip

# ─────────────────────────────────────────────────────────────────────────────
# Шифрование банковских токенов (Revolut, site.pro)
# ─────────────────────────────────────────────────────────────────────────────
# Отдельный ключ для Fernet-шифрования credentials в core/encryption.py.
# Если пуст — fallback на SECRET_KEY (только для обратной совместимости со
# старыми инсталляциями; в проде включается warning).
#
# Сгенерировать ключ (минимум 32 символа):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
ENCRYPTION_KEY=

# Список старых ключей для расшифровки токенов, ещё не пересохранённых
# новым ENCRYPTION_KEY (нужен только во время ротации). Comma-separated.
# После прогона `python manage.py rotate_encryption_key` можно очистить.
# Подробности: docs/ENCRYPTION_KEY.md
ENCRYPTION_KEY_FALLBACKS=

# Включить fail-fast в проде: settings упадут, если ENCRYPTION_KEY не
# задан или короче 32 символов или совпадает с SECRET_KEY. Поставить в
# `true` ПОСЛЕ задания ENCRYPTION_KEY и (при необходимости) ротации.
ENCRYPTION_KEY_REQUIRED=False

# Database Settings (PostgreSQL)
DB_NAME=logist2_db
DB_USER=logist2_user
DB_PASSWORD=your-strong-database-password
DB_HOST=localhost
DB_PORT=5432

# PgBouncer (рекомендуется для прода).
#   USE_PGBOUNCER=true:
#     - DB_PORT обычно = 6432 (порт PgBouncer)
#     - CONN_MAX_AGE=0 (PgBouncer сам пулит коннекты)
#     - DISABLE_SERVER_SIDE_CURSORS=True (transaction-mode pool несовместим
#       с cursor.itersize)
#     - PgBouncer должен быть в pool_mode=transaction
#
#   Установка на сервере (Ubuntu):
#     apt install pgbouncer
#     /etc/pgbouncer/pgbouncer.ini:
#       [databases]
#       logist2_db = host=127.0.0.1 port=5432 dbname=logist2_db
#       [pgbouncer]
#       listen_port = 6432
#       pool_mode = transaction
#       max_client_conn = 1000
#       default_pool_size = 25
#     systemctl enable --now pgbouncer
USE_PGBOUNCER=false

# Опционально: используется только скриптом scripts\sync_db.ps1 для синка
# продакшн-БД на локальную машину. Если не задано — fallback на DB_PASSWORD.
#   LOCAL_DB_PASSWORD  — пароль локального PostgreSQL (для psql/pg_restore).
#   REMOTE_DB_PASSWORD — пароль PostgreSQL на сервере (для pg_dump по ssh).
LOCAL_DB_PASSWORD=
REMOTE_DB_PASSWORD=

# Security Settings
CSRF_TRUSTED_ORIGINS=https://caromoto-lt.com,https://www.caromoto-lt.com
# CORS не используется: frontend живёт на том же origin (caromoto-lt.com).
# Если когда-то понадобится открыть API внешнему фронту/мобильному приложению —
# подключить django-cors-headers (см. M2 в docs/ROADMAP_2026-05_high_medium.md).

# Email Settings (опционально, для отправки уведомлений)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# AI Settings (для AI чата)
AI_CHAT_ENABLED=True
AI_API_KEY=your-openai-api-key-here

# Anthropic Claude API key — используется для:
#   1) Invoice audit (core/services/invoice_audit_service.py)
#   2) AI-обработка сканов титулов и Dock Receipt
#      (core/services/scan_extractor.py)
# Модель по умолчанию: claude-sonnet-4-20250514 (vision-capable).
ANTHROPIC_API_KEY=sk-ant-...
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=400
AI_TEMPERATURE=0.2
AI_EMBEDDINGS_MODEL=text-embedding-3-small
AI_RAG_INDEX_PATH=
AI_RAG_TOP_K=4
AI_RAG_MAX_AGE_HOURS=24

# Media and Static Files
MEDIA_ROOT=/var/www/caromoto-lt/media
STATIC_ROOT=/var/www/caromoto-lt/static

# Sentry (error monitoring) — оставьте SENTRY_DSN пустым, чтобы отключить
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_PII=False

# Django settings module.
#
# По умолчанию загружается через дефолты в manage.py / wsgi.py / asgi.py /
# celery.py:
#   - локально:  logist2.settings.dev  (DEBUG=True, debug-toolbar)
#   - сервер:    logist2.settings.prod (выставляется systemd unit'ами,
#                см. scripts/gunicorn.service, daphne.service, celery.service)
#   - тесты:     logist2.settings.test (CI .github/workflows/ci.yml +
#                pyproject.toml [tool.pytest.ini_options])
#
# Раскомментируйте только если нужно вручную переопределить:
# DJANGO_SETTINGS_MODULE=logist2.settings.prod

# ─────────────────────────────────────────────────────────────────────────────
# Gmail OAuth — переписка по контейнерам (Phase 1: чтение, Phase 2: отправка)
# ─────────────────────────────────────────────────────────────────────────────
# Включение/выключение синхронизации с Gmail.
GMAIL_ENABLED=false
# OAuth 2.0 Desktop client — получить через Google Cloud Console (Logist2-email).
GMAIL_CLIENT_ID=816142178998-xxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx
# Refresh token — получить один раз через scripts/get_gmail_refresh_token.py
# (scopes: gmail.readonly + gmail.send).
GMAIL_REFRESH_TOKEN=1//0xxxxxxxxxxxxxxxx
# Почтовый ящик, к которому выдан токен (для справки/логов; API определяет сам).
GMAIL_USER_EMAIL=user@caromoto.com
# Сколько дней писем тянуть при первом прогоне (когда ещё нет history_id).
GMAIL_INITIAL_LOOKBACK_DAYS=30
# Лимит размера одного вложения для скачивания (МБ). Крупнее — только метаданные.
GMAIL_MAX_ATTACHMENT_MB=25

# ─── Phase 2: отправка писем ───────────────────────────────────────────────
# Отображаемое имя отправителя (From).
GMAIL_FROM_NAME=Caromoto Lithuania
# Email отправителя. Пусто = использовать GMAIL_USER_EMAIL.
# Если хотим слать от alias — alias должен быть настроен в Gmail
# → Settings → Accounts → Send mail as.
GMAIL_FROM_EMAIL=
# Подпись (plain text). Добавляется в конец каждого исходящего письма.
GMAIL_SIGNATURE_TEXT="--\nCaromoto Lithuania\nhttps://caromoto-lt.com"
# Подпись (HTML).
GMAIL_SIGNATURE_HTML="<p style='color:#6b7280;font-size:13px;'>--<br>Caromoto Lithuania<br><a href='https://caromoto-lt.com'>caromoto-lt.com</a></p>"
# Макс. суммарный размер вложений исходящего письма (МБ).
GMAIL_MAX_OUTBOUND_MB=25

# ─────────────────────────────────────────────────────────────────────────────
# Google Drive API — синхронизация фотографий контейнеров
# ─────────────────────────────────────────────────────────────────────────────
# Публичный API key (НЕ OAuth). Нужен, чтобы получать ПОЛНЫЙ список файлов
# в больших папках Drive (HTML-парсинг режет выдачу на ~100 элементов). Если
# пусто — система откатится на старый HTML-метод (с обрезкой).
#
# Получить: Google Cloud Console → APIs → enable "Google Drive API" →
# Credentials → Create API key → Restrict to Drive API.
# Папки должны быть публичные (Anyone with the link can view).
GOOGLE_DRIVE_API_KEY=

